TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: restrict the bot to one Telegram user ID.
# Leave blank to allow any user who starts the bot.
TELEGRAM_USER_ID=

# Dashboard base URL used by /month.
BASE_URL=http://localhost:8080

# Reminder settings.
MOOD_TIMEZONE=Asia/Taipei
DAILY_REMINDER_TIME=22:00
FOLLOW_UP_MINUTES=60

# Local storage.
DATABASE_PATH=mood.db
PORT=8080
